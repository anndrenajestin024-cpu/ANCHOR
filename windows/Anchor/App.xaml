<Application
    x:Class="Anchor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AnchorCream">#FFFAF9F5</Color>
            <Color x:Key="AnchorCharcoal">#FF131417</Color>
            <Color x:Key="AnchorPrimary">#FF55565B</Color>
            <Color x:Key="AnchorMuted">#FFA6A7AC</Color>
            <Color x:Key="AnchorSuccess">#FF5E7A4C</Color>
            <Color x:Key="AnchorWarn">#FFD0A050</Color>
            <Color x:Key="AnchorDanger">#FFB85C48</Color>

            <SolidColorBrush x:Key="AnchorCreamBrush" Color="{StaticResource AnchorCream}" />
            <SolidColorBrush x:Key="AnchorCharcoalBrush" Color="{StaticResource AnchorCharcoal}" />
            <SolidColorBrush x:Key="AnchorPrimaryBrush" Color="{StaticResource AnchorPrimary}" />
            <SolidColorBrush x:Key="AnchorMutedBrush" Color="{StaticResource AnchorMuted}" />
            <SolidColorBrush x:Key="AnchorSuccessBrush" Color="{StaticResource AnchorSuccess}" />
            <SolidColorBrush x:Key="AnchorWarnBrush" Color="{StaticResource AnchorWarn}" />
            <SolidColorBrush x:Key="AnchorDangerBrush" Color="{StaticResource AnchorDanger}" />

            <!-- Bundled font files (not system fonts) so the typefaces render identically on every
                 machine. Plain relative paths, not ms-appx:// URIs — this app is unpackaged (no MSIX
                 identity), and ms-appx resolution throws without one, crashing the app at startup
                 before any window shows since these are eagerly loaded Application resources. -->
            <FontFamily x:Key="GordenFont">Assets/Fonts/Gorden.otf#Gorden</FontFamily>
            <FontFamily x:Key="AvianoSerifFont">Assets/Fonts/AvianoSerif.otf#Aviano Serif</FontFamily>
            <FontFamily x:Key="AvianoGothicFont">Assets/Fonts/AvianoGothic.ttf#Aviano Gothic  3</FontFamily>
            <FontFamily x:Key="GaleyFont">Assets/Fonts/Galey-Regular.ttf#Galey Rounded ExtLt</FontFamily>

            <!-- Fluent controls (Button, NavigationViewItem, ContentDialog, TextBox, ComboBox, ...)
                 read their default font from this theme resource rather than an implicit
                 TextBlock style, so it has to be overridden too for the lock to be complete. -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Assets/Fonts/AvianoGothic.ttf#Aviano Gothic  3</FontFamily>

            <!-- IsTextScaleFactorEnabled defaults to true, meaning Windows' "Make text
                 bigger" Ease of Access setting resizes every TextBlock automatically.
                 Disable it so font size is controlled purely by the FontSize values
                 set in code/XAML, not the system. -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AvianoGothicFont}" />
                <Setter Property="IsTextScaleFactorEnabled" Value="False" />
            </Style>
            <Style x:Key="AnchorHeadingTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AvianoSerifFont}" />
                <Setter Property="IsTextScaleFactorEnabled" Value="False" />
            </Style>
            <Style x:Key="AnchorWordmarkTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource GordenFont}" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="IsTextScaleFactorEnabled" Value="False" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
