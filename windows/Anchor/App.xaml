<Application
    x:Class="Anchor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AnchorCream">#FFFAF9F5</Color>
            <Color x:Key="AnchorCharcoal">#FF131417</Color>
            <Color x:Key="AnchorPrimary">#FF55565B</Color>
            <Color x:Key="AnchorMuted">#FFA6A7AC</Color>
            <Color x:Key="AnchorSuccess">#FF5E7A4C</Color>
            <Color x:Key="AnchorWarn">#FFD0A050</Color>
            <Color x:Key="AnchorDanger">#FFB85C48</Color>
            <Color x:Key="AnchorOutlineFaint">#FFE4E5E9</Color>

            <SolidColorBrush x:Key="AnchorCreamBrush" Color="{StaticResource AnchorCream}" />
            <SolidColorBrush x:Key="AnchorCharcoalBrush" Color="{StaticResource AnchorCharcoal}" />
            <SolidColorBrush x:Key="AnchorPrimaryBrush" Color="{StaticResource AnchorPrimary}" />
            <SolidColorBrush x:Key="AnchorMutedBrush" Color="{StaticResource AnchorMuted}" />
            <SolidColorBrush x:Key="AnchorSuccessBrush" Color="{StaticResource AnchorSuccess}" />
            <SolidColorBrush x:Key="AnchorWarnBrush" Color="{StaticResource AnchorWarn}" />
            <SolidColorBrush x:Key="AnchorDangerBrush" Color="{StaticResource AnchorDanger}" />
            <SolidColorBrush x:Key="AnchorOutlineFaintBrush" Color="{StaticResource AnchorOutlineFaint}" />

            <!-- Bundled font files (not system fonts) so the typefaces render identically on every
                 machine. pack://siteoforigin is WPF's scheme for loose files that ship next to the
                 exe (Content, not embedded resources) — no package identity required, unlike
                 WinUI3's ms-appx:// which needs an MSIX identity this app doesn't have. -->
            <FontFamily x:Key="GordenFont">pack://siteoforigin:,,,/Assets/Fonts/Gorden.otf#Gorden</FontFamily>
            <FontFamily x:Key="AvianoSerifFont">pack://siteoforigin:,,,/Assets/Fonts/AvianoSerif.otf#Aviano Serif</FontFamily>
            <FontFamily x:Key="AvianoGothicFont">pack://siteoforigin:,,,/Assets/Fonts/AvianoGothic.ttf#Aviano Gothic  3</FontFamily>
            <FontFamily x:Key="GaleyFont">pack://siteoforigin:,,,/Assets/Fonts/Galey-Regular.ttf#Galey Rounded ExtLt</FontFamily>

            <!-- Default font + size lock for every TextBlock/Control: WPF has no
                 "make text bigger" OS text-scale factor the way WinUI3 does, so no
                 extra opt-out is needed to keep sizes exactly what's set here. -->
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{StaticResource AvianoGothicFont}" />
            </Style>
            <Style TargetType="{x:Type Control}">
                <Setter Property="FontFamily" Value="{StaticResource AvianoGothicFont}" />
            </Style>
            <Style x:Key="AnchorHeadingTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AvianoSerifFont}" />
            </Style>
            <Style x:Key="AnchorWordmarkTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource GordenFont}" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>

            <Style x:Key="AnchorFieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource AnchorMutedBrush}" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
