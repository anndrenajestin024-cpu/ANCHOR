<Window
    x:Class="Anchor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Anchor"
    xmlns:views="using:Anchor.Views">

    <Grid Background="{StaticResource AnchorCreamBrush}">
        <Grid x:Name="LockRoot" Visibility="Visible">
            <views:LockView x:Name="LockViewControl" />
        </Grid>

        <Grid x:Name="ShellRoot" Visibility="Collapsed">
            <NavigationView x:Name="Nav"
                             IsSettingsVisible="True"
                             IsBackButtonVisible="Collapsed"
                             ItemInvoked="Nav_ItemInvoked"
                             SelectionChanged="Nav_SelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" />
                    <NavigationViewItem Content="Purchases" Tag="purchases" Icon="Shop" />
                    <NavigationViewItem Content="Quotes" Tag="quotes" Icon="Bookmarks" />
                    <NavigationViewItem Content="Suppliers" Tag="suppliers" Icon="People" />
                    <NavigationViewItem Content="Budgets" Tag="budgets" Icon="PieSingleSeries" />
                    <NavigationViewItem Content="Reminders" Tag="reminders" Icon="Clock" />
                </NavigationView.MenuItems>
                <Grid Padding="24">
                    <ContentPresenter x:Name="ContentHost" />
                </Grid>
            </NavigationView>
        </Grid>
    </Grid>
</Window>
