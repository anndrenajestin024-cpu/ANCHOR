<Window
    x:Class="Anchor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Anchor.Views"
    Title="Anchor" Height="820" Width="1180"
    Background="{StaticResource AnchorCreamBrush}">

    <Grid>
        <Grid x:Name="LockRoot" Visibility="Visible">
            <views:LockView x:Name="LockViewControl" />
        </Grid>

        <Grid x:Name="ShellRoot" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="#FF131417">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,20,16,24" VerticalAlignment="Center">
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="Assets/profile-photo.jpg" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Anchor" Style="{StaticResource AnchorWordmarkTextStyle}" FontSize="18" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1" x:Name="NavPanel" Margin="8,0" />

                <Button Grid.Row="2" x:Name="SettingsButton" Content="⚙ Settings" HorizontalAlignment="Stretch" Margin="8,0,8,16" Padding="10,8" Click="SettingsButton_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" />
            </Grid>

            <!-- Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border x:Name="GreetBar" Grid.Row="0" Visibility="Collapsed" Padding="18,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF232428" Offset="0" />
                            <GradientStop Color="#FF46474B" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="GreetText" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" />
                </Border>
                <Grid Grid.Row="1" Margin="28">
                    <ContentControl x:Name="ContentHost" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
