<ContentDialog
    x:Class="Anchor.Views.AddQuoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add a quote"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <ScrollViewer MaxHeight="440">
        <StackPanel Spacing="10" Width="380">
            <ComboBox x:Name="GroupBox" Header="Comparison" HorizontalAlignment="Stretch" SelectionChanged="GroupBox_SelectionChanged" />
            <TextBox x:Name="NewTitleBox" Header="New comparison name" Visibility="Collapsed" />
            <ComboBox x:Name="CategoryBox" Header="Category" HorizontalAlignment="Stretch" Visibility="Collapsed" />
            <TextBox x:Name="SupplierBox" Header="Supplier" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="QtyBox" Header="Qty" Text="1" Width="120" />
                <TextBox x:Name="PriceBox" Header="Unit price" Width="180" />
            </StackPanel>
            <TextBox x:Name="ValidUntilBox" Header="Valid until (yyyy-mm-dd)" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
