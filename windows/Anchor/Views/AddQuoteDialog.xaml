<Window
    x:Class="Anchor.Views.AddQuoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add a quote"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
    Background="{StaticResource AnchorCreamBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="440">
            <StackPanel Width="380">
                <TextBlock Text="Comparison" Style="{StaticResource AnchorFieldLabel}" />
                <ComboBox x:Name="GroupBox" HorizontalAlignment="Stretch" Margin="0,0,0,10" SelectionChanged="GroupBox_SelectionChanged" />
                <StackPanel x:Name="NewTitlePanel" Visibility="Collapsed">
                    <TextBlock Text="New comparison name" Style="{StaticResource AnchorFieldLabel}" />
                    <TextBox x:Name="NewTitleBox" Padding="6" Margin="0,0,0,10" />
                </StackPanel>
                <StackPanel x:Name="CategoryPanel" Visibility="Collapsed">
                    <TextBlock Text="Category" Style="{StaticResource AnchorFieldLabel}" />
                    <ComboBox x:Name="CategoryBox" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                </StackPanel>
                <TextBlock Text="Supplier" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="SupplierBox" Padding="6" Margin="0,0,0,10" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Qty" Style="{StaticResource AnchorFieldLabel}" />
                        <TextBox x:Name="QtyBox" Text="1" Padding="6" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unit price" Style="{StaticResource AnchorFieldLabel}" />
                        <TextBox x:Name="PriceBox" Padding="6" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="Valid until (yyyy-mm-dd)" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="ValidUntilBox" Padding="6" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="14,7" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Save" Padding="14,7" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
