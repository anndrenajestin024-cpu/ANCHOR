<Window
    x:Class="Anchor.Views.PurchaseDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Purchase detail"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
    Background="{StaticResource AnchorCreamBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="480">
            <StackPanel x:Name="DetailPanel" Width="380" />
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Delete" Padding="14,7" Margin="0,0,8,0" Click="OnDeleteClick" />
            <Button Content="Close" Padding="14,7" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
