<UserControl
    x:Class="Anchor.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="900" HorizontalAlignment="Stretch">
            <StackPanel x:Name="RangeChips" Orientation="Horizontal" Spacing="8" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock Text="TOTAL SPEND" FontSize="10" Foreground="{StaticResource AnchorMutedBrush}" />
                        <TextBlock x:Name="TotalSpendText" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock x:Name="TotalSpendSub" FontSize="11" Foreground="{StaticResource AnchorMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock Text="SAVINGS" FontSize="10" Foreground="{StaticResource AnchorMutedBrush}" />
                        <TextBlock x:Name="SavingsText" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="vs highest quotes" FontSize="11" Foreground="{StaticResource AnchorMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock Text="BUDGET VARIANCE" FontSize="10" Foreground="{StaticResource AnchorMutedBrush}" />
                        <TextBlock x:Name="VarianceText" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock x:Name="VarianceSub" FontSize="11" Foreground="{StaticResource AnchorMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource AnchorMutedBrush}" />
                        <TextBlock x:Name="PendingText" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock x:Name="PendingSub" FontSize="11" Foreground="{StaticResource AnchorMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="White" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="SPEND BY CATEGORY" FontSize="11" Foreground="{StaticResource AnchorPrimaryBrush}" FontWeight="SemiBold" />
                    <StackPanel x:Name="CategoryList" Margin="0,12,0,0" Spacing="10" />
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="RECENT PURCHASES" FontSize="11" Foreground="{StaticResource AnchorPrimaryBrush}" FontWeight="SemiBold" />
                    <StackPanel x:Name="RecentList" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
