<UserControl
    x:Class="Anchor.Views.LockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource AnchorCharcoalBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Width="320">
            <TextBlock Text="Anchor" Foreground="White" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock x:Name="TitleText" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,20,0,0" />
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource AnchorMutedBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,20" />

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource AnchorDangerBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D1" Grid.Column="0" Content="1" Click="DigitClick" Margin="4" />
                <Button x:Name="D2" Grid.Column="1" Content="2" Click="DigitClick" Margin="4" />
                <Button x:Name="D3" Grid.Column="2" Content="3" Click="DigitClick" Margin="4" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D4" Grid.Column="0" Content="4" Click="DigitClick" Margin="4" />
                <Button x:Name="D5" Grid.Column="1" Content="5" Click="DigitClick" Margin="4" />
                <Button x:Name="D6" Grid.Column="2" Content="6" Click="DigitClick" Margin="4" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D7" Grid.Column="0" Content="7" Click="DigitClick" Margin="4" />
                <Button x:Name="D8" Grid.Column="1" Content="8" Click="DigitClick" Margin="4" />
                <Button x:Name="D9" Grid.Column="2" Content="9" Click="DigitClick" Margin="4" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="" IsEnabled="False" Margin="4" Opacity="0" />
                <Button x:Name="D0" Grid.Column="1" Content="0" Click="DigitClick" Margin="4" />
                <Button x:Name="DBack" Grid.Column="2" Content="⌫" Click="BackClick" Margin="4" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
