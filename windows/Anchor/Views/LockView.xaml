<UserControl
    x:Class="Anchor.Views.LockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.18,1">
                <GradientStop Color="#FF8E8F94" Offset="0" />
                <GradientStop Color="#FF55565B" Offset="0.38" />
                <GradientStop Color="#FF2E2F33" Offset="0.70" />
                <GradientStop Color="#FF0E0F12" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18">
            <Ellipse Width="42" Height="42">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/anchor-logo.png" Stretch="UniformToFill" />
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="Anchor" Style="{StaticResource AnchorWordmarkTextStyle}" Foreground="White" FontSize="22" VerticalAlignment="Center" Margin="11,0,0,0" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
            <Ellipse Width="130" Height="130" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/profile-photo.jpg" Stretch="UniformToFill" />
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="Rodney Cedrick Rozario" Style="{StaticResource AnchorHeadingTextStyle}" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16" />
            <TextBlock x:Name="TitleText" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock x:Name="SubtitleText" Foreground="#FFDDDDDD" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,20" />

            <TextBlock x:Name="ErrorText" Foreground="#FFE8A18C" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D1" Grid.Column="0" Content="1" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D2" Grid.Column="1" Content="2" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D3" Grid.Column="2" Content="3" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D4" Grid.Column="0" Content="4" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D5" Grid.Column="1" Content="5" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D6" Grid.Column="2" Content="6" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="D7" Grid.Column="0" Content="7" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D8" Grid.Column="1" Content="8" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D9" Grid.Column="2" Content="9" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
            </Grid>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="" IsEnabled="False" Margin="4" Padding="8" Opacity="0" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="D0" Grid.Column="1" Content="0" Click="DigitClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
                <Button x:Name="DBack" Grid.Column="2" Content="⌫" Click="BackClick" Margin="4" Padding="8" Style="{StaticResource AnchorPinKeyStyle}" />
            </Grid>

            <Button x:Name="ForgotPinButton" Content="Forgot PIN?" HorizontalAlignment="Center" Background="Transparent" Foreground="#FFCCCCCC"
                    BorderThickness="0" Padding="4" FontSize="12" Click="ForgotPin_Click" />
        </StackPanel>
    </Grid>
</UserControl>
