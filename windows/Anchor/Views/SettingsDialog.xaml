<ContentDialog
    x:Class="Anchor.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Close"
    PrimaryButtonClick="OnSaveClick">

    <ScrollViewer MaxHeight="520">
        <StackPanel Spacing="10" Width="380">
            <TextBox x:Name="OwnerBox" Header="Your name" />
            <ComboBox x:Name="CurrencyBox" Header="Currency" HorizontalAlignment="Stretch" />
            <TextBox x:Name="BudgetAlertBox" Header="Budget alert % (70-100)" />
            <ComboBox x:Name="AutoLockBox" Header="Auto-lock" HorizontalAlignment="Stretch" />

            <Button Content="Lock now" HorizontalAlignment="Stretch" Click="LockNow_Click" Margin="0,8,0,0" />

            <TextBlock Text="BACKUP &amp; RESTORE" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock x:Name="BackupMsg" FontSize="12" TextWrapping="Wrap" Text="Backup is a single file with all purchases, quotes, suppliers, budgets and reminders." />
            <Button Content="Download backup" HorizontalAlignment="Stretch" Click="DownloadBackup_Click" />
            <Button Content="Restore from backup" HorizontalAlignment="Stretch" Click="RestoreBackup_Click" />

            <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,0" />
            <Button Content="Reset to sample data" HorizontalAlignment="Stretch" Click="ResetSample_Click" />
            <Button Content="Clear all data" HorizontalAlignment="Stretch" Click="ClearAll_Click" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
