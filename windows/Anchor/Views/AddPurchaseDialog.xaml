<Window
    x:Class="Anchor.Views.AddPurchaseDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Log a purchase"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
    Background="{StaticResource AnchorCreamBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="480">
            <StackPanel Width="380">
                <TextBlock Text="Item" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="ItemBox" Padding="6" Margin="0,0,0,10" />
                <TextBlock Text="Category" Style="{StaticResource AnchorFieldLabel}" />
                <ComboBox x:Name="CategoryBox" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                <TextBlock Text="Supplier" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="SupplierBox" Padding="6" Margin="0,0,0,10" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Qty" Style="{StaticResource AnchorFieldLabel}" />
                        <TextBox x:Name="QtyBox" Text="1" Padding="6" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unit" Style="{StaticResource AnchorFieldLabel}" />
                        <ComboBox x:Name="UnitBox" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="Unit price" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="PriceBox" Padding="6" Margin="0,0,0,10" />
                <TextBlock Text="Date (yyyy-mm-dd)" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="DateBox" Padding="6" Margin="0,0,0,10" />
                <TextBlock Text="Status" Style="{StaticResource AnchorFieldLabel}" />
                <ComboBox x:Name="StatusBox" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                <TextBlock Text="Attachment" Style="{StaticResource AnchorFieldLabel}" />
                <ComboBox x:Name="AttachBox" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                <TextBlock Text="Notes" Style="{StaticResource AnchorFieldLabel}" />
                <TextBox x:Name="NotesBox" AcceptsReturn="True" Height="60" Padding="6" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="14,7" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Save" Padding="14,7" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
