<ContentDialog
    x:Class="Anchor.Views.AddPurchaseDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Log a purchase"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <ScrollViewer MaxHeight="480">
        <StackPanel Spacing="10" Width="380">
            <TextBox x:Name="ItemBox" Header="Item" />
            <ComboBox x:Name="CategoryBox" Header="Category" HorizontalAlignment="Stretch" />
            <TextBox x:Name="SupplierBox" Header="Supplier" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="QtyBox" Header="Qty" Text="1" Width="120" />
                <ComboBox x:Name="UnitBox" Header="Unit" Width="120" />
            </StackPanel>
            <TextBox x:Name="PriceBox" Header="Unit price" />
            <TextBox x:Name="DateBox" Header="Date (yyyy-mm-dd)" />
            <ComboBox x:Name="StatusBox" Header="Status" HorizontalAlignment="Stretch" />
            <ComboBox x:Name="AttachBox" Header="Attachment" HorizontalAlignment="Stretch" />
            <TextBox x:Name="NotesBox" Header="Notes" AcceptsReturn="True" Height="60" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
