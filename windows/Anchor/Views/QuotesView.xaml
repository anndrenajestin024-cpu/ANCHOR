<UserControl
    x:Class="Anchor.Views.QuotesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Content="+ Add quote" Padding="10,6" HorizontalAlignment="Right" Margin="0,0,0,10" Click="AddButton_Click" />
        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="GroupsList" MaxWidth="700" HorizontalAlignment="Stretch" />
        </ScrollViewer>
    </Grid>
</UserControl>
