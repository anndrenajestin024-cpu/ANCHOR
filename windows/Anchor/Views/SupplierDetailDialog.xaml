<Window
    x:Class="Anchor.Views.SupplierDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Supplier"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
    Background="{StaticResource AnchorCreamBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="480">
            <StackPanel x:Name="DetailPanel" Width="380" />
        </ScrollViewer>

        <Button Grid.Row="1" Content="Close" Padding="14,7" HorizontalAlignment="Right" Margin="0,16,0,0" Click="Close_Click" />
    </Grid>
</Window>
